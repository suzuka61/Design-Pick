{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["content/**/*.ts", "background/**/*.ts", "analyzer/**/*.ts", "generator/**/*.ts", "renderer/**/*.ts", "types/**/*.ts"],
  "exclude": ["node_modules", "dist", "sidepanel"]
}